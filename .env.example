# Copy to ".env.local" and fill in values. Never commit real secrets.

# --- Vite (browser) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key

# --- Local API server + Vercel (Node) ---
# Same project as above; server code does not read VITE_* unless you duplicate here:
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_public_key
# Dashboard → Settings → API → "service_role" (secret). Required for /api cron, token row, SMS batch, previews.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- RingCentral (JWT auth app) ---
RINGCENTRAL_CLIENT_ID=
RINGCENTRAL_CLIENT_SECRET=
RINGCENTRAL_SERVER_URL=https://platform.ringcentral.com
# Developer Console → your name → Credentials → Create JWT. Paste the full JWT string (starts with eyJ...).
# Aliases also work: RINGCENTRAL_USER_JWT, RC_USER_JWT (must be in this file — VITE_* is not visible to the API).
RINGCENTRAL_JWT=
# E.164 sender on the **same RingCentral extension** as the JWT user (Admin → Users → that user → numbers).
RINGCENTRAL_SMS_FROM_NUMBER=+1XXXXXXXXXX

# --- Cron / run ---
CRON_SECRET=generate_a_long_random_string
